/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    ucsd-cmi/compass Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default config options for all compute environments
----------------------------------------------------------------------------------------
*/

// Global default params, used in configs
params {

    // Input options
    input                      = null

    // MultiQC options
    multiqc_config             = null
    multiqc_title              = null
    multiqc_logo               = null
    max_multiqc_email_size     = '25.MB'
    multiqc_methods_description = null

    // Boilerplate options
    outdir                       = null
    publish_dir_mode             = 'copy'
    email                        = null
    email_on_fail                = null
    plaintext_email              = false
    monochrome_logs              = false
    help                         = false
    help_full                    = false
    show_hidden                  = false
    version                      = false
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/ucsd-cmi/compass-resources/refs/heads/main/test_data/'
    trace_report_suffix          = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')

    // Workflow mode
    workflow_mode                                       = ""

    // Schema validation default options
    validate_params                                     = true

    // Reference databases and adapters
    ref_databases                                       = null
    shotgun_adapter_list                                = null

    // Shotgun preprocessing
    shotgun_do_preprocessing                            = true
    shotgun_preprocessing_min_read_length               = 15
    shotgun_preprocessing_fastp_qualified_quality_phred = 15
    shotgun_preprocessing_fastp_cut_tail                = false

    // Shotgun host removal
    shotgun_do_host_removal                             = true
    shotgun_host_removal_bowtie2_very_sensitive         = true

    // Shotgun read pairing
    shotgun_do_read_pairing                             = true

    // Shotgun run merging
    shotgun_do_run_merging                              = false

    // Shotgun profiling
    shotgun_do_kraken2                                  = true
    shotgun_do_kraken2_filtering                        = false
    shotgun_kraken2_filtering_taxids                    = null
    shotgun_kraken2_filtering_mode                      = "exclude"
    shotgun_kraken2_filtering_include_parents           = false
    shotgun_kraken2_filtering_include_children          = false
    shotgun_do_bracken                                  = true

    // Shotgun profiling standardisation
    shotgun_do_profiling_standardisation                = false
    shotgun_profiling_standardisation_format            = 'tsv'
    shotgun_taxpasta_taxonomy                           = null
    shotgun_taxpasta_add_name                           = false
    shotgun_taxpasta_add_rank                           = false
    shotgun_taxpasta_add_lineage                        = false
    shotgun_taxpasta_add_id_lineage                     = false
    shotgun_taxpasta_add_rank_lineage                   = false

    // Amplicon general
    amplicon_random_seed                                = 66
    amplicon_paired_end_data                            = true

    // Amplicon preprocessing
    amplicon_do_cutadapt                                = true
    amplicon_minimum_read_count                         = 1
    amplicon_forward_primer                             = ""
    amplicon_reverse_primer                             = ""
    amplicon_minimum_primer_overlap                     = 3
    amplicon_maximum_primer_error_rate                  = 0.1
    amplicon_calculate_trunclen                         = true
    amplicon_calculate_trunclen_quality_threshold       = 20
    amplicon_trunclen_forward                           = 0
    amplicon_trunclen_reverse                           = 0
    amplicon_truncate_below_read_quality                = 2
    amplicon_trim_left                                  = 0
    amplicon_trim_right                                 = 0
    amplicon_maximum_length_before_trimming             = -1
    amplicon_minimum_length_after_trimming              = 50
    amplicon_maximum_expected_error                     = -1
    amplicon_abort_failed_preprocessing                 = false

    // Amplicon ASV inference
    amplicon_do_remove_chimeras                         = true

    // Amplicon taxonomic classification
    amplicon_do_taxonomic_classification_dada2          = false
    amplicon_taxonomic_classification_dada2_min_boot    = 50
    amplicon_do_taxonomic_classification_dada2_species  = false
    amplicon_taxonomic_classification_species_multiple  = false
    amplicon_do_taxonomic_classification_qiime2         = true

    // Amplicon phylogenetic placement
    amplicon_do_phylogenetic_placement                  = true

    // Amplicon taxa filtering
    amplicon_taxa_to_exclude                            = null
    amplicon_minimum_abundance                          = 1
    amplicon_minimum_prevalence                         = 1

    // Amplicon analysis
    amplicon_do_rarefaction                             = true
    amplicon_rarefaction_minimum_sample_depth           = 500
    amplicon_taxonomy_for_analysis                      = "qiime2"
    amplicon_do_export_sequences_absolute               = true
    amplicon_do_export_sequences_relative               = true
    amplicon_do_export_taxonomy_absolute                = true
    amplicon_export_taxonomy_absolute_collapse_levels   = "6"
    amplicon_do_export_taxonomy_relative                = true
    amplicon_export_taxonomy_relative_collapse_levels   = "6"
    amplicon_do_export_taxonomy_barplot                 = true
    amplicon_do_alpha_diversity                         = true
    amplicon_alpha_diversity_metrics                    = "shannon,observed_features"
    amplicon_do_alpha_diversity_phylogenetic            = true
    amplicon_alpha_diversity_phylogenetic_metrics       = "faith_pd"
    amplicon_do_beta_diversity                          = true
    amplicon_beta_diversity_metrics                     = "braycurtis,jaccard"
    amplicon_do_beta_diversity_phylogenetic             = true
    amplicon_beta_diversity_phylogenetic_metrics        = "unweighted_unifrac,weighted_normalized_unifrac"
}

// Load base.config by default for all pipelines
includeConfig 'conf/base.config'

profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }
    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        conda.channels          = ['conda-forge', 'bioconda']
        apptainer.enabled       = false
    }
    mamba {
        conda.enabled           = true
        conda.useMamba          = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }
    arm64 {
        process.arch            = 'arm64'
        // TODO https://github.com/nf-core/modules/issues/6694
        // For now if you're using arm64 you have to use wave for the sake of the maintainers
        // wave profile
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }
    emulate_amd64 {
        docker.runOptions       = '-u $(id -u):$(id -g) --platform=linux/amd64'
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    podman {
        podman.enabled          = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    shifter {
        shifter.enabled         = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    charliecloud {
        charliecloud.enabled    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        apptainer.enabled       = false
    }
    apptainer {
        apptainer.enabled       = true
        apptainer.autoMounts    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    wave {
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }
    gpu {
        docker.runOptions       = '-u $(id -u):$(id -g) --gpus all'
        apptainer.runOptions    = '--nv'
        singularity.runOptions  = '--nv'
    }
    test          { includeConfig 'conf/test.config'          }
    test_amplicon { includeConfig 'conf/test_amplicon.config' }
}



// Set default registry for Apptainer, Docker, Podman, Charliecloud and Singularity independent of -profile
// Will not be used unless Apptainer / Docker / Podman / Charliecloud / Singularity are enabled
// Set to your registry if you have a mirror of containers
apptainer.registry    = 'quay.io'
docker.registry       = 'quay.io'
podman.registry       = 'quay.io'
singularity.registry  = 'quay.io'
charliecloud.registry = 'quay.io'



// Export these variables to prevent local Python/R libraries from conflicting with those in the container
// The JULIA depot path has been adjusted to a fixed path `/usr/local/share/julia` that needs to be used for packages in the container.
// See https://apeltzer.github.io/post/03-julia-lang-nextflow/ for details on that. Once we have a common agreement on where to keep Julia packages, this is adjustable.

env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
}

// Set bash options
process.shell = [
    "bash",
    "-C",         // No clobber - prevent output redirection from overwriting files.
    "-e",         // Exit if a tool returns a non-zero status/exit code
    "-u",         // Treat unset variables and parameters as an error
    "-o",         // Returns the status of the last command to exit..
    "pipefail"    //   ..with a non-zero status or zero if all successfully execute
]

// Disable process selector warnings by default. Use debug profile to enable warnings.
nextflow.enable.configProcessNamesValidation = false

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${params.trace_report_suffix}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${params.trace_report_suffix}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${params.trace_report_suffix}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${params.trace_report_suffix}.html"
}

manifest {
    name            = 'ucsd-cmi/compass'
    contributors    = [
        [
            name: 'Cassidy Symons',
            affiliation: 'Center for Microbiome Innovation at UC San Diego',
            email: 'csymons@ucsd.edu',
            github: 'cassidysymons',
            contribution: ['author', 'maintainer'], // List of contribution types ('author', 'maintainer' or 'contributor')
        ],
        [
            name: 'Se Jin Song',
            affiliation: 'Center for Microbiome Innovation at UC San Diego',
            email: 'j0s001@ucsd.edu',
            github: 'sejsong',
            contribution: ['contributor'], // List of contribution types ('author', 'maintainer' or 'contributor')
        ],
        [
            name: 'Tyler Myers',
            affiliation: 'Center for Microbiome Innovation at UC San Diego',
            email: 'tdmyers@ucsd.edu',
            github: 'tydymy',
            contribution: ['contributor'], // List of contribution types ('author', 'maintainer' or 'contributor')
        ],
    ]
    homePage        = 'https://github.com/ucsd-cmi/compass'
    description     = """COMPASS - COmprehensive Metagenomics Platform for Automated Sequence Solutions"""
    mainScript      = 'main.nf'
    defaultBranch   = 'master'
    nextflowVersion = '!>=25.04.0'
    version         = '0.1.0'
    doi             = ''
}

// Nextflow plugins
plugins {
    id 'nf-schema@2.5.1' // Validation of pipeline parameters and creation of an input channel from a sample sheet
}

validation {
    defaultIgnoreParams = ["genomes"]
    monochromeLogs = params.monochrome_logs
}

// Load modules.config for DSL2 module specific options
includeConfig 'conf/modules.config'
